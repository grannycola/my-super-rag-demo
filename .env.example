# LLM (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Embeddings: bge-small | bge-base | e5-base | openai
EMBEDDING_PROVIDER=bge-small
EMBEDDING_MODEL=bge-small
# Required only when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# Vector store: chroma | qdrant
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=data/processed/chroma
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docsrag

# Retrieval & reranking
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
USE_BM25=false
USE_HYBRID=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
EVAL_QUESTIONS_PATH=data/eval_questions.jsonl
REPORTS_DIR=reports

# Logging
LOG_LEVEL=INFO

# Admin API key for /ingest and /evaluate (header: X-Admin-Key)
ADMIN_API_KEY=
